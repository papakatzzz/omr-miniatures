---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Locale } from '../i18n';

export interface Props {
  title: string;
  description: string;
  locale?: Locale;
  canonical?: string;
  ogImage?: string;
}

const { title, description, locale = 'en', canonical, ogImage = '/og-image.png' } = Astro.props;
const siteUrl = 'https://omrminiatures.eu';
const canon = canonical ?? (siteUrl + Astro.url.pathname);
---
<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canon} />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canon} />
  <meta property="og:image" content={siteUrl + ogImage} />
  <meta property="og:site_name" content="O.M.R Miniatures" />
  <meta property="og:locale" content={locale === 'en' ? 'en_US' : locale === 'es' ? 'es_ES' : 'it_IT'} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={siteUrl + ogImage} />

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <Header locale={locale} />
  <main>
    <slot />
  </main>
  <Footer locale={locale} />
  <script>
    // Header scroll effect
    const header = document.querySelector('.site-header');
    const onScroll = () => header?.classList.toggle('scrolled', window.scrollY > 40);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Mobile nav
    const burger = document.querySelector('.burger');
    const nav = document.querySelector('.nav-links');
    burger?.addEventListener('click', () => nav?.classList.toggle('open'));

    // Wishlist count
    function updateWishlistCount() {
      try {
        const wl = JSON.parse(localStorage.getItem('omr_wishlist') || '[]');
        document.querySelectorAll('.wishlist-count').forEach(el => {
          el.textContent = wl.length > 0 ? String(wl.length) : '';
        });
      } catch {}
    }
    updateWishlistCount();
    window.addEventListener('wishlist-updated', updateWishlistCount);
  </script>
</body>
</html>
