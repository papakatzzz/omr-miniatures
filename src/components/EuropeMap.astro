  // ── PERSIA ────────────────────────────────────────────────────────────────
  364: 'persia',

  // ── AFGHANISTAN ───────────────────────────────────────────────────────────
    4: 'afghanistan',

  // ── SIAM (Thailand — independent buffer state) ────────────────────────────
  764: 'siam',

  // ── INDEPENDENT AFRICAN STATES ────────────────────────────────────────────
  231: 'ethiopia',
  430: 'liberia',

  // ── LATIN AMERICA ─────────────────────────────────────────────────────────
   32: 'argentina',
   68: 'bolivia',
   76: 'brazil',
  152: 'chile',
  170: 'colombia',
  188: 'costa-rica',
  192: 'cuba',
  214: 'dominican-republic',
  218: 'ecuador',
  222: 'el-salvador',
  320: 'guatemala',
  332: 'haiti',
  340: 'honduras',
  484: 'mexico',
  558: 'nicaragua',
  591: 'panama',
  600: 'paraguay',
  604: 'peru',
  858: 'uruguay',
  862: 'venezuela',
