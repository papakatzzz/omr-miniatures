  // ── PERSIA ────────────────────────────────────────────────────────────────
  364: 'persia',

  // ── AFGHANISTAN ───────────────────────────────────────────────────────────
    4: 'afghanistan',

  // ── SIAM (Thailand — independent buffer state) ────────────────────────────
  764: 'siam',

  // ── INDEPENDENT AFRICAN STATES ────────────────────────────────────────────
  231: 'ethiopia',
